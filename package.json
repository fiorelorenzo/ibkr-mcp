{
  "name": "@fiorelorenzo/ibkr-mcp",
  "version": "0.1.5",
  "description": "MCP server for Interactive Brokers — account, options chains, analytics (BS/Greeks/IV/PMCC), market context.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fiorelorenzo/ibkr-mcp.git"
  },
  "homepage": "https://github.com/fiorelorenzo/ibkr-mcp#readme",
  "bugs": {
    "url": "https://github.com/fiorelorenzo/ibkr-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ibkr-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "format": "prettier --write src test",
    "smoke": "tsx test/smoke/run.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stoqey/ib": "^1.5.5",
    "yahoo-finance2": "^3.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
